# Backend Environment Variables Template
# In Cloudflare Workers, environmental secrets are mapped via:
# `npx wrangler secret put KEY_NAME`
# For local dev, copy this file to server/.dev.vars and add values.

# ==========================================
# Authentication & Security
# ==========================================
# The secret phrase used to log into the Admin Dashboard
ADMIN_API_KEY=your_secure_admin_password_here

# Whitelisted Origins for CORS mapping (comma separated)
CORS_ORIGIN=https://your-domain.com,https://localhost:5173

# ==========================================
# Application Settings
# ==========================================
# Used for backend link generation (e.g., in email templates)
SITE_URL=https://your-domain.com

# ==========================================
# Email & Integrations
# ==========================================
# The API key for Resend email provider (Optional)
RESEND_API_KEY=your_resend_secret_key_here

# Email address to receive critical system notifications
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com
