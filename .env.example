# Frontend Environment Variables Template
# Copy this file to .env.local and fill in the values.
# IMPORTANT: Never commit actual keys to version control!

# ==========================================
# Core API & Site Configuration
# ==========================================
# The base URL for the backend API (e.g., https://your-worker.workers.dev)
VITE_API_URL=your_api_url_here

# The public URL of this frontend application (e.g., https://sltech.vn)
VITE_SITE_URL=your_site_url_here

# URL for your Content Delivery Network (e.g., R2 Bucket public URL)
VITE_CDN_URL=your_cdn_url_here

# ==========================================
# Third-Party Integrations
# ==========================================
# Google Analytics 4 Measurement ID (Format: G-XXXXXXXXXX)
VITE_GA_ID=your_ga4_measurement_id_here

# Zalo Official Account ID (for the chat widget)
VITE_ZALO_OA_ID=your_zalo_oa_id_here

# Cloudflare Turnstile Site Key (for bot protection on Contact & RFQ forms)
# Get this from: https://dash.cloudflare.com > Turnstile > Add Site
# Leave empty for local development (forms will work without CAPTCHA)
VITE_TURNSTILE_SITE_KEY=
